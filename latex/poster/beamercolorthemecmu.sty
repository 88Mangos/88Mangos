% ====================
% Definitions
% ====================

% Color Palette
% From https://brand.cmu.edu/visual-identity/colors
% Primary
\definecolor{carnegiered}{RGB}{196, 18, 48}
\definecolor{black}{RGB}{0, 0, 0}
\definecolor{irongray}{RGB}{109, 110, 113}
\definecolor{steelgray}{RGB}{224, 224, 224}
\definecolor{white}{RGB}{255, 255, 255}

% Secondary
\definecolor{rose}{RGB}{239, 58, 71} % scots rose 
\definecolor{gold}{RGB}{253, 181, 21} % gold thread 
\definecolor{green}{RGB}{0, 150, 71} % green thread 
\definecolor{teal}{RGB}{0, 143, 145} % teal thread 
\definecolor{blue}{RGB}{4, 54, 115} % blue thread 
\definecolor{skyblue}{RGB}{0, 123, 192} % highlands sky blue 

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=gold}

% Headline
\setbeamercolor{headline}{fg=steelgray,bg=carnegiered}
\setbeamercolor{headline rule}{bg=steelgray}

% Block
\setbeamercolor{block title}{fg=carnegiered,bg=white}
\setbeamercolor{block separator}{bg=black}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=carnegiered,bg=lightgray}
\setbeamercolor{block alerted separator}{bg=black}
\setbeamercolor{block alerted body}{fg=black,bg=lightgray}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=darkgray}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
\setbeamertemplate{bibliography entry article}{}
\setbeamertemplate{bibliography entry title}{}
\setbeamertemplate{bibliography entry location}{}
\setbeamertemplate{bibliography entry note}{}